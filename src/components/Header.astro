---
import { SITE_TITLE, GITHUB_URL } from '../consts';
const { pathname } = Astro.url;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + '/');
---

<header class="border-b border-gray-200 sticky top-0 bg-white/95 backdrop-blur z-10">
  <nav class="max-w-2xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-semibold text-gray-900 hover:text-indigo-600 transition-colors text-sm">
      {SITE_TITLE}
    </a>
    <div class="flex items-center gap-6 text-sm">
      <a href="/about" class={`transition-colors ${isActive('/about') ? 'text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-900'}`}>
        About
      </a>
      <a href="/blog" class={`transition-colors ${isActive('/blog') ? 'text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-900'}`}>
        Blog
      </a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-900 transition-colors">
        GitHub
      </a>
    </div>
  </nav>
</header>
