          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Currently Learning -->
  <section class="mb-12">
    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-6">Currently Learning</h2>
    <div class="space-y-4">
      <div class="flex gap-4 items-start">
        <span class="text-indigo-400 text-xs mt-0.5 shrink-0">▸</span>
        <div>
          <p class="text-sm font-medium text-gray-900">CMU 15-445 Database Systems</p>
