      <div>
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Languages</h3>
        <div class="flex flex-wrap gap-2">
          {["Java", "C/C++", "Kotlin", "Golang", "Scala", "Python"].map(s => (
            <span class="px-2.5 py-1 text-xs bg-gray-100 text-gray-700 rounded-full">{s}</span>
