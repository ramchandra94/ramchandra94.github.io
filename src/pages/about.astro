---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<BaseLayout title="About — G.V Rama Chandra" description={SITE_DESCRIPTION}>

  <!-- Header -->
  <section class="mb-12 pb-10 border-b border-gray-100">
    <h1 class="text-2xl font-bold text-gray-900 mb-1">G.V Rama Chandra</h1>
    <p class="text-indigo-600 text-sm font-medium mb-4">SDE2 at Amazon · IIT Kharagpur</p>
    <p class="text-gray-600 text-sm leading-relaxed mb-6 max-w-xl">
      Software Engineer with 7+ years of experience across distributed systems, backend platforms,
      and ML engineering. Currently working on Route53 DNS infrastructure at Amazon.
      I started my career in machine learning, moved into backend and platform engineering,
      and now work on large-scale DNS systems. I'm drawn to problems that require both depth and scale.
    </p>
    <div class="flex items-center gap-5 text-sm flex-wrap">
      <a href="https://github.com/ramchandra94" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-900 transition-colors">GitHub →</a>
      <a href="https://www.linkedin.com/in/ramachandragobburu" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-900 transition-colors">LinkedIn →</a>
      <a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-900 transition-colors">Resume →</a>
    </div>
  </section>

