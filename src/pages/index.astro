---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION, GITHUB_URL, LINKEDIN_URL } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="relative reveal mb-14 pb-10 border-b border-gray-100" style="animation-delay: 0ms">
    <div aria-hidden="true" class="dot-grid pointer-events-none absolute -inset-x-10 -top-16 h-64"></div>
    <div class="relative">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.25em] text-indigo-600 mb-3">Software Engineer</p>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 mb-3">G.V Rama Chandra</h1>
        </div>
        <div class="font-mono text-sm font-medium text-indigo-600 h-12 w-12 shrink-0 rounded-xl border border-indigo-200 bg-indigo-50/60 flex items-center justify-center">
          RC
        </div>
      </div>
      <p class="font-mono text-xs text-gray-500 mb-6">
        SDE II @ Amazon · Route&nbsp;53 &nbsp;//&nbsp; 9+ years &nbsp;//&nbsp; IIT Kharagpur
      </p>
      <p class="text-[15px] text-gray-600 leading-relaxed max-w-xl mb-7">
        I work on Amazon Route&nbsp;53 DNS infrastructure and large-scale data processing. My
        background spans ML engineering, distributed systems, and backend platforms. I write here
        about distributed systems, backend design, and architecture — to clarify my own thinking.
      </p>
      <div class="flex flex-wrap items-center gap-2">
        <a href="/about" class="group inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-sm text-gray-700 transition-colors hover:border-indigo-300 hover:text-indigo-600">
          About <span class="text-gray-400 transition-transform group-hover:translate-x-0.5 group-hover:text-indigo-500">→</span>
        </a>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-sm text-gray-700 transition-colors hover:border-indigo-300 hover:text-indigo-600">
          GitHub <span class="text-gray-400 transition-transform group-hover:translate-x-0.5 group-hover:text-indigo-500">↗</span>
        </a>
        {LINKEDIN_URL && (
          <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-sm text-gray-700 transition-colors hover:border-indigo-300 hover:text-indigo-600">
            LinkedIn <span class="text-gray-400 transition-transform group-hover:translate-x-0.5 group-hover:text-indigo-500">↗</span>
          </a>
        )}
        <a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-sm text-gray-700 transition-colors hover:border-indigo-300 hover:text-indigo-600">
          Résumé <span class="text-gray-400 transition-transform group-hover:translate-x-0.5 group-hover:text-indigo-500">↓</span>
        </a>
      </div>
    </div>
  </section>

  <section class="reveal" style="animation-delay: 100ms">
    <div class="flex items-center gap-3 mb-6">
      <h2 class="font-mono text-xs uppercase tracking-[0.2em] text-gray-500">Recent Posts</h2>
      <span class="flex-1 h-px bg-gray-200"></span>
      <a href="/blog" class="font-mono text-[11px] text-gray-400 hover:text-indigo-600 transition-colors shrink-0">all →</a>
    </div>
    {posts.length > 0 ? (
      posts.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={post.id}
        />
      ))
    ) : (
      <p class="text-sm text-gray-400 py-6">Posts coming soon.</p>
    )}
  </section>
</BaseLayout>
